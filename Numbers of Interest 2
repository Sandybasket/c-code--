#include <stdio.h>
#include <stdlib.h>

#define MAX_N 1000000

int spf[MAX_N + 1];
int sum_div[MAX_N + 1];
long long f[MAX_N + 1];
long long g[MAX_N + 1];

void precompute() {
    for (int i = 0; i <= MAX_N; i++) {
        spf[i] = i;
    }
    for (int i = 2; i * i <= MAX_N; i++) {
        if (spf[i] == i) {
            for (int j = i * i; j <= MAX_N; j += i) {
                if (spf[j] == j) {
                    spf[j] = i;
                }
            }
        }
    }
    spf[0] = 0;
    spf[1] = 0;

    for (int i = 1; i <= MAX_N; i++) {
        for (int j = 2 * i; j <= MAX_N; j += i) {
            sum_div[j] += i;
        }
    }

    f[0] = 0; g[0] = 0;
    f[1] = 0; g[1] = 0;
    for (int i = 2; i <= MAX_N; i++) {
        f[i] = f[i - 1] + spf[i];
        g[i] = g[i - 1] + sum_div[i];
    }
}

int main() {
    precompute();

    int t;
    if (scanf("%d", &t) != 1) return 0;

    while (t--) {
        int n;
        if (scanf("%d", &n) != 1) break;

        long long ans = (f[n] + g[n]) % n;
        printf("%lld\n", ans);
    }

    return 0;
}

